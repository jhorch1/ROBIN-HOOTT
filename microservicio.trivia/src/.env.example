# ─── Configuración del Microservicio Trivia ──────────────────────────────────
# Copiá este archivo como .env y completá los valores según tu entorno

# Puerto en el que corre el microservicio
PUERTO=5002

# URL del backend principal de Robin HOOT
URL_BACKEND=http://localhost:5001

# URL base de la API pública Open Trivia Database
URL_OPENTDB=https://opentdb.com

# Tiempo límite por defecto para preguntas importadas (en segundos)
# OpenTDB no provee este dato, se usa este valor al crear preguntas en el backend
TIEMPO_LIMITE_DEFAULT=30

# Tiempo de vida del caché de categorías (en segundos)
# Las categorías de OpenTDB son estables, 1 hora es suficiente
CACHE_CATEGORIAS_TTL=3600

# Timeout máximo para llamadas a OpenTDB (en milisegundos)
TIMEOUT_OPENTDB=5000

# Timeout máximo para llamadas al backend principal (en milisegundos)
TIMEOUT_BACKEND=10000

# Tiempo de espera antes de reintentar una llamada fallida a OpenTDB (en milisegundos)
DELAY_REINTENTO=1000
