{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seeders.js",
    "lint": "eslint src/ server.js seeders.js",
    "lint:fix": "eslint src/ server.js seeders.js --fix",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns=src/tests",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns=src/tests --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 89,
        "functions": 90,
        "branches": 60
      }
    },
    "collectCoverageFrom": [
      "src/middlewares/errorHandler.js",
      "src/middlewares/auth.js",
      "src/controllers/juegoController.js",
      "src/controllers/categoriaController.js",
      "src/controllers/preguntaController.js",
      "src/routes/juegoRoutes.js",
      "src/routes/categoriaRoutes.js",
      "src/routes/preguntaRoutes.js",
      "src/routes/usuarioRoutes.js",
      "src/routes/rolRoutes.js",
      "src/routes/opcionRespuestaRoutes.js",
      "src/routes/productoRoutes.js",
      "src/routes/triviaRoutes.js",
      "src/modules/sessions/session.routes.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.3",
    "morgan": "^1.10.1",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "jest": "^30.3.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
